pipeline {
  agent any

  parameters {
    string(name: 'AIWEBTEST_PLAN', defaultValue: 'examples/plan.demo_create_employee.yaml', description: 'Path to the AI WebTester plan YAML to run')
    string(name: 'AIWEBTEST_ENV', defaultValue: 'examples/env.local.yaml', description: 'Path to the AI WebTester environment YAML to run')
    string(name: 'AIWEBTEST_EXTRA_ARGS', defaultValue: '--no-headful', description: 'Optional extra CLI flags, for example --hooks myapp.testing.hooks')
  }

  environment {
    OPENAI_API_KEY = credentials('openai-api-key')
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install Dependencies') {
      steps {
        script {
          if (isUnix()) {
            sh 'python3 -m pip install -e ".[dev]"'
            sh 'playwright install --with-deps chromium'
          } else {
            bat 'python -m pip install -e ".[dev]"'
            bat 'playwright install chromium'
          }
        }
      }
    }

    stage('Run AI WebTester') {
      steps {
        script {
          // Replace the default demo values with your own files, for example:
          // python -m cli.main run --plan tests/ai/plan.login.yaml --env tests/ai/env.ci.yaml --no-headful
          if (isUnix()) {
            sh "python3 -m cli.main run --plan ${params.AIWEBTEST_PLAN} --env ${params.AIWEBTEST_ENV} ${params.AIWEBTEST_EXTRA_ARGS}"
          } else {
            bat "python -m cli.main run --plan ${params.AIWEBTEST_PLAN} --env ${params.AIWEBTEST_ENV} ${params.AIWEBTEST_EXTRA_ARGS}"
          }
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'artifacts/**', fingerprint: true, allowEmptyArchive: true
    }
  }
}
