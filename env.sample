# AI WebTester Framework - Environment Configuration
# Copy this file to .env and fill in your actual values

# OpenAI API Key (Required for AI-powered test generation)
# Get your API key from: https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Control Room Configuration
# CONTROL_ROOM_PORT=8788
# CONTROL_ROOM_HOST=127.0.0.1

# Optional: Mock App Configuration  
# MOCK_APP_PORT=5000
# MOCK_APP_HOST=127.0.0.1

# Optional: Test Execution Settings
# DEFAULT_TIMEOUT=30000
# DEFAULT_SLOW_MO=500
# ARTIFACTS_DIR=artifacts
# HEADFUL_MODE=true